# --- Required (one of these two) ---
# Anthropic takes priority when both are set.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- Required for backend ---
# PostgreSQL connection string. Defaults to the value below if unset.
DATABASE_URL=postgresql://localhost:5432/northstar

# --- Optional: model selection ---
# Default chat/agent model.
MODEL_NAME=claude-sonnet-4-5-20250929
# Model used when running session evals via /eval-runs.
EVAL_MODEL=claude-opus-4-7
# Model used as the judge / scorer for evals.
JUDGE_MODEL=claude-sonnet-4-5-20250929

# --- Optional: agent behavior ---
# Max conversation rounds before the agent forces a phase advance.
MAX_QUESTION_ROUNDS=3

# --- Optional: embeddings (Tier 2 — kNN scoring, distribution signals) ---
# Voyage AI API key. Required for any session that uses kNN-against-labels
# scorers or the embedding-status endpoint. Without it the backfill endpoint
# returns 400 and the kNN voter abstains from every row.
VOYAGE_API_KEY=
# Override the default embedding model (voyage-3-lite, 512d). Changing this
# mid-corpus is a foot-gun — cosine values aren't comparable across models.
EMBEDDING_MODEL=

# --- Optional: Braintrust integration ---
# User-scoped key for triggering eval runs from the UI (also accepted via
# the X-Braintrust-Key header per request).
BRAINTRUST_API_KEY=
# Production-only key for online scorers / monitoring.
BRAINTRUST_PROD_API_KEY=
BRAINTRUST_PROD_PROJECT=north-star-prod

# --- Optional: GitHub integration ---
# PAT used to fetch private skill repos when importing a SKILL.md.
GITHUB_TOKEN=

# --- Frontend (Vite) ---
# Backend API base URL. Defaults to "/api" (proxied via Vite in dev).
VITE_API_URL=/api

# --- Evals harness ---
# Backend service URL used by evals/run_eval.py.
NORTH_STAR_URL=http://localhost:8080
