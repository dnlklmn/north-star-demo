{
  "name": "northstar-runner-container",
  "version": "0.1.0",
  "private": true,
  "description": "RunFeature container service. Wraps the Claude Agent SDK behind an HTTP seam matching backend/app/contracts.py RunFeatureRequest/RunFeatureResult.",
  "type": "module",
  "main": "dist/server.js",
